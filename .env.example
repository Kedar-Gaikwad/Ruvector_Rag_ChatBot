# Copy this file to .env and fill in your values.
# .env is gitignored - never commit real credentials.
#
# These are only needed for LOCAL development with docker compose.
# On EC2 the container runs with --network host and picks up the
# IAM instance role automatically via the metadata service.

AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_SESSION_TOKEN=                          # leave blank unless using SSO / assumed role
