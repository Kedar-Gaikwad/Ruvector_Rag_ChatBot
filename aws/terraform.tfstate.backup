            "source_dest_check": true,
            "spot_instance_request_id": "",
            "subnet_id": "subnet-09353e50494b99adf",
            "tags": {
              "Name": "ruvector-rag-chatbot"
            },
            "tags_all": {
              "Name": "ruvector-rag-chatbot"
            },
            "tenancy": "default",
            "timeouts": null,
            "user_data": "#!/bin/bash\n# =============================================================================\n# Ruvector RAG Chatbot — EC2 Bootstrap Script\n# Variables are substituted by Terraform templatefile() before launch.\n# Logs are written to /var/log/user-data.log for easy debugging via SSM.\n# =============================================================================\nset -e\nexec \u003e\u003e /var/log/user-data.log 2\u003e\u00261\necho \"=== user_data START: $(date) ===\"\n\n# --- Update \u0026 install prerequisites ---\napt-get update -y\napt-get install -y ca-certificates curl gnupg git\n\n# --- Install Docker (modern method for Ubuntu 22.04+) ---\n# The old 'apt-key add' approach is deprecated. Use signed keyring instead.\ninstall -m 0755 -d /etc/apt/keyrings\ncurl -fsSL https://download.docker.com/linux/ubuntu/gpg \\\n  | gpg --dearmor -o /etc/apt/keyrings/docker.gpg\nchmod a+r /etc/apt/keyrings/docker.gpg\n\necho \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \\\nhttps://download.docker.com/linux/ubuntu jammy stable\" \\\n  \u003e /etc/apt/sources.list.d/docker.list\n\napt-get update -y\napt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin\nsystemctl enable docker\nsystemctl start docker\necho \"Docker ready: $(docker --version)\"\n\n# --- Set up workspace ---\nmkdir -p /home/ubuntu/ruvector-rag\n\n# --- Clone the RAG project source ---\n# --- Clone RuVector ---\ncd /home/ubuntu\ngit clone https://github.com/ruvnet/ruvector.git ruvector_src\n\n# --- Clone your RAG app ---\ngit clone https://github.com/Kedar-Gaikwad/rag_app.git rag_app\n\n# --- Create docker-compose ---\ncat \u003e /home/ubuntu/docker-compose.yml \u003c\u003cEOF\nversion: \"3.8\"\n\nservices:\n  ruvector:\n    image: ruvnet/ruvector:latest\n    container_name: ruvector-db\n    restart: always\n    ports:\n      - \"5432:5432\"\n\n  rag-app:\n    build:\n      context: /home/ubuntu/rag_app\n      dockerfile: Dockerfile\n    container_name: rag-chatbot\n    restart: always\n    ports:\n      - \"80:8000\"\n    environment:\n      - EMBEDDING_PROVIDER=bedrock\n      - LLM_PROVIDER=bedrock\n      - AWS_REGION=us-east-1\n      - OPENAI_API_KEY=\n      - RUVECTOR_URL=http://ruvector:6333\n    depends_on:\n      - ruvector\nEOF\n\ncd /home/ubuntu\n\ndocker compose -f docker-compose.yml build rag-app\ndocker compose -f docker-compose.yml up -d\n\necho \"Deployment complete\"",
            "user_data_base64": null,
            "user_data_replace_on_change": true,
            "volume_tags": null,
            "vpc_security_group_ids": [
